{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "incremental": false /* Disable incremental cache while debugging this */
  },
  "include": ["src/main.ts", "src/**/*"],
  "exclude": [
    "node_modules",
    "**/node_modules/*",
    "dist",
    "test",
    "**/*spec.ts"
  ]
}
